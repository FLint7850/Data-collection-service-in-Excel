+def clean_supplier_model_display(value: str) -> str:
+    """Финальная очистка модели поставщика без брендовых/цветовых костылей."""
+    model = normalize_model_letters(clean_text(str(value or "")))
+    model = re.sub(r"\([^)]*\)|\[[^\]]*\]|\{[^}]*\}", " ", model)
+    model = re.sub(r"[^A-Za-z0-9./_\-\s]+", " ", model)
+    model = re.sub(r"\s+", " ", model).strip()
+    model = model.strip(" -—–.,;:")
+
+    # Убираем пробелы вокруг модельных разделителей, но не трогаем пробелы между токенами модели.
+    model = re.sub(r"\s*/\s*", "/", model)
+    model = re.sub(r"\s*\.\s*", ".", model)
+    model = re.sub(r"\s*_\s*", "_", model)
+    model = re.sub(r"\s+-\s+", "-", model)
+
+    return model.strip(" -—–.,;:")
+
+
+def supplier_brand_variants(brand: str) -> List[str]:
+    """Возвращает regex-варианты бренда из БД, включая бренды из нескольких слов."""
+    normalized = normalize_model_letters(clean_text(str(brand or "")))
+    if not normalized:
+        return []
+
+    words = re.findall(r"[A-Za-z0-9]+", normalized)
+    if not words:
+        return []
+
+    escaped_words = [re.escape(word) for word in words]
+    variants = [r"\s+".join(escaped_words)]
+
+    if len(escaped_words) > 1:
+        # Zigmund & Shtain / Just Aircon / Schaub Lorenz.
+        variants.append(r"\s*(?:&|and)?\s*".join(escaped_words))
+
+    return variants
+
+
+def supplier_brand_regex() -> str:
+    patterns: List[str] = []
+    for brand in sorted(model_brand_names(), key=len, reverse=True):
+        patterns.extend(supplier_brand_variants(brand))
+    return "|".join(patterns)
+
+
+def first_compact_model_token(value: str) -> str:
+    """Возвращает первый цельный код модели вида ZC045BY0/SJ-653GHXJ52R/DX-194.490BK."""
+    for match in SUPPLIER_MODEL_TOKEN_RE.finditer(value):
+        token = clean_supplier_model_display(match.group(0))
+        if (
+            token
+            and any(char.isdigit() for char in token)
+            and bool(re.search(r"[A-Za-z]", token))
+            and re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9./_-]{2,}", token)
+        ):
+            return token
+    return ""
+
+
+def should_collapse_to_first_compact_model(candidate: str) -> bool:
+    """Определяет случаи, когда после цельного кода идёт описание отделки/цвета.
+
+    Это не список цветов. Правило общее: если после первого цельного кода модели идут
+    только английские слова без цифр и без модельных символов, считаем их описанием.
+    Пример: ZC045MY0 Metallic Silver -> ZC045MY0.
+    """
+    tokens = [clean_supplier_model_display(match.group(0)) for match in SUPPLIER_MODEL_TOKEN_RE.finditer(candidate)]
+    tokens = [token for token in tokens if token]
+    if len(tokens) < 2:
+        return False
+
+    first = tokens[0]
+    if not first_compact_model_token(first):
+        return False
+
+    tail = tokens[1:]
+    if not tail or len(tail) > 4:
+        return False
+
+    return all(
+        re.fullmatch(r"[A-Za-z]{2,24}", token)
+        and not any(char.isdigit() for char in token)
+        and "-" not in token
+        and "/" not in token
+        and "." not in token
+        and "_" not in token
+        for token in tail
+    )
+
+
+def extract_supplier_model_after_brand(value: str) -> str:
+    text = normalize_model_letters(clean_text(str(value or "")))
+    if not text:
+        return ""
+
+    # Удаляем комментарии в скобках и берём основную часть до запятой/точки с запятой.
+    text = re.sub(r"\([^)]*\)|\[[^\]]*\]|\{[^}]*\}", " ", text)
+    head = re.split(r"[,;]", text, maxsplit=1)[0]
+    head = clean_text(head)
+
+    brands_regex = supplier_brand_regex()
+    if not brands_regex:
+        return ""
+
+    match = re.search(
+        rf"(?<![A-Za-zА-Яа-яЁё0-9])(?:{brands_regex})(?![A-Za-zА-Яа-яЁё0-9])\s+(.+)$",
+        head,
+        flags=re.IGNORECASE,
+    )
+    if not match:
+        return ""
+
+    candidate = clean_supplier_model_display(match.group(1))
+    if not candidate:
+        return ""
+
+    if should_collapse_to_first_compact_model(candidate):
+        candidate = first_compact_model_token(candidate)
+
+    if any(char.isdigit() for char in candidate) and bool(re.search(r"[A-Za-z]", candidate)):
+        return candidate
+
+    return ""
+
+
