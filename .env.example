# Runtime paths
LOG_DIR=logs
FEED_DIR=feeds
LOGS_FILE=logs/logs.json
UNIFIED_LOG_FILE=logs/app.log
EXPORT_DIR=exports
FILE_IMPORT_DIR=storage/file-import
# WAL лучше для сценария “много чтений + периодические записи”: интерфейс меньше блокируется, пока фоновые потоки пишут состояние.
# DELETE обычный безопасный режим SQLite, один файл app.db, меньше проблем на Windows/Docker bind mounts.
SQLITE_JOURNAL_MODE=DELETE

# Defaults for projects and news feeds
DEFAULT_START_URL=
DEFAULT_FEED_URL=https://mega-kuhnya.ru/price/last_modified.xml
DEFAULT_FEED_GENERATE_URL=https://mega-kuhnya.ru/index.php?route=extension/feed/unixml/new_product
DEFAULT_EXCLUSIONS=/catalog/rasprodazha/,/catalog/utsenka/,/about/,/contacts/
APP_TIMEZONE_OFFSET_HOURS=3

# Network and concurrency
REQUEST_TIMEOUT=20
CONNECTION_METHOD_TIMEOUT_SECONDS=60
REQUEST_DELAY_SECONDS=0.05
MAX_RETRIES=3
FEED_WORKER_COUNT=3
FEED_SNAPSHOT_CACHE_SECONDS=120
FEED_SNAPSHOT_RETAIN=3
NEWS_SCAN_STALL_TIMEOUT=180
SCHEDULE_DUE_GRACE_SECONDS=90
CONNECTION_METHOD_CACHE_SECONDS=30
PROGRESS_STREAM_INTERVAL_SECONDS=2
# Optional background HTTP Basic Auth rules for protected supplier feeds.
# Keep real credentials only in .env; this example value must remain empty.
SUPPLIER_FEED_BASIC_AUTH_RULES_JSON=
BLOCKED_PAGE_MARKERS=cloudflare,captcha,access denied,http 403,__qrator,qauth.js,qrator,доступ ограничен,проверяем ваш браузер,enable javascript

# Browser selection
# Optional absolute path. Leave empty to use Playwright chromium-headless-shell for headless methods.
PLAYWRIGHT_BROWSER_EXECUTABLE=
FORCE_BROWSER_SETUP=0
FETCH_DEBUG_HTML=0

# SMTP defaults. Empty DB fields fall back to these values.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_RECIPIENTS=
YANDEX_SMTP_PASSWORD=

# Flask/Gunicorn
PORT=5000
FLASK_SECRET_KEY=change-this-secret-key
DEBUG_HANG_DUMP=0
WEB_CONCURRENCY=1
WEB_THREADS=2
WEB_TIMEOUT=180
WEB_GRACEFUL_TIMEOUT=30
WEB_KEEPALIVE=5
LOG_LEVEL=info
GUNICORN_ACCESS_LOG=0

# First user is created automatically when the users table is empty.
AUTH_DEFAULT_USERNAME=admin
AUTH_DEFAULT_PASSWORD=admin
