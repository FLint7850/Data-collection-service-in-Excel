# Пути относительно корня проекта или абсолютные пути
DATABASE_PATH=data/app.db
LOG_DIR=logs
FEED_DIR=feeds
LOGS_FILE=logs/logs.json
UNIFIED_LOG_FILE=logs/app.log
EXPORT_DIR=exports
FILE_IMPORT_DIR=storage/file-import

# Дефолты проектов и новинок
DEFAULT_START_URL=
DEFAULT_FEED_URL=https://mega-kuhnya.ru/price/last_modified.xml
DEFAULT_FEED_GENERATE_URL=https://mega-kuhnya.ru/index.php?route=extension/feed/unixml/new_product
DEFAULT_EXCLUSIONS=/catalog/rasprodazha/,/catalog/utsenka/,/about/,/contacts/
APP_TIMEZONE_OFFSET_HOURS=3

# Сетевые настройки и параллельность
REQUEST_TIMEOUT=20
CONNECTION_METHOD_TIMEOUT_SECONDS=60
REQUEST_DELAY_SECONDS=0.05
MAX_RETRIES=3
FEED_WORKER_COUNT=6
NEWS_ENRICH_WORKER_COUNT=8
# Одновременно выполняющиеся сканы раздела «Новинки»; остальные ждут в FIFO-очереди.
NEWS_MAX_CONCURRENT_SCANS=3
NEWS_SCAN_STALL_TIMEOUT=180
SCHEDULE_DUE_GRACE_SECONDS=90
CONNECTION_METHOD_CACHE_SECONDS=30
BLOCKED_PAGE_MARKERS=cloudflare,captcha,access denied,http 403,__qrator,qauth.js,qrator,доступ ограничен,проверяем ваш браузер,enable javascript

# SMTP-дефолты. Если в БД поле пустое, настройки новинок подтянутся отсюда.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_RECIPIENTS=

# Совместимость со старым именем переменной
YANDEX_SMTP_PASSWORD=

# Опциональные внешние сервисы
FIRECRAWL_API_KEY=

# Flask / production server
HOST=127.0.0.1
PORT=5055
PRODUCTION_THREADS=8
MAX_UPLOAD_MB=100
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
ALLOW_INSECURE_DEFAULTS=0
DEBUG_HANG_DUMP=0
FLASK_SECRET_KEY=change-this-secret-key
FORCE_BROWSER_SETUP=0

# Первый пользователь создается автоматически, если таблица users пустая
AUTH_DEFAULT_USERNAME=admin
AUTH_DEFAULT_PASSWORD=admin
